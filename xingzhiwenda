                        <img src="https://p3-doubao-search-sign.byteimg.com/labis/a7b954fb159684ced8edd5c3a86c5d78~tplv-be4g95zd3a-image.jpeg?lk3s=feb11e32&x-expires=1789972064&x-signature=APTK5p2aDKPtEZnC2GfXRNw%2FPS0%3D" alt="陶行知先生" class="w-full h-full object-cover">
                    </div>
                    <div class="bg-blue-900 bg-opacity-60 rounded-lg p-4">
                        <p class="text-white font-medium mb-1">陶行知先生</p>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </div>
            `;
            chatContainer.insertAdjacentHTML('beforeend', typingHTML);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // 移除正在输入的指示器
        function removeTypingIndicator() {
            const typingIndicator = document.getElementById('typing-indicator');
            if (typingIndicator) {
                typingIndicator.remove();
            }
        }

        // 查找匹配的回答
        function findAnswer(question) {
            question = question.toLowerCase();
            
            // 检查是否有完全匹配的关键词
            for (const qa of qaDatabase) {
                for (const keyword of qa.keywords) {
                    if (question.includes(keyword.toLowerCase())) {
                        return qa.answer;
                    }
                }
            }
            
            // 如果没有完全匹配，返回默认回答
            return `
                感谢您的提问。作为一名教育工作者，我认为教育是立国之本，是民族复兴的基础。

                我的教育理念可以概括为"生活即教育"、"社会即学校"、"教学做合一"。我相信教育应该与生活相结合，应该在实践中学习，应该培养学生的创造力和实践能力。

                作为师范生，我建议你：

                1. 要"以教人者教己"，不断提高自己的专业素养和道德修养。

                2. 要"在劳力上劳心"，注重理论与实践的结合。

                3. 要"爱满天下"，热爱学生，热爱教育事业。

                4. 要注重培养学生的道德品质，因为"道德是做人的根本"。

                如果你有更具体的问题，我很乐意进一步探讨。
            `;
        }

        // 处理用户输入
        function handleUserInput() {
            const message = userInput.value.trim();
            if (message === '') return;
            
            // 添加用户消息
            addUserMessage(message);
            
            // 清空输入框
            userInput.value = '';
            
            // 添加正在输入的指示器
            addTypingIndicator();
            
            // 模拟思考时间
            setTimeout(() => {
                // 移除正在输入的指示器
                removeTypingIndicator();
                
                // 查找并添加回答
                const answer = findAnswer(message);
                addTeacherMessage(answer);
            }, 1500);
        }

        // 发送按钮点击事件
        sendButton.addEventListener('click', handleUserInput);

        // 输入框回车事件
        userInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                handleUserInput();
            }
        });

        // 建议问题点击事件
        suggestionButtons.forEach(button => {
            button.addEventListener('click', function() {
                userInput.value = this.textContent.trim();
                handleUserInput();
            });
        });
    </script>

</body></html>
